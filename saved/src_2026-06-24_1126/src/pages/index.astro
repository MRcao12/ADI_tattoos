---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import SectionTitle from '../components/SectionTitle.astro';
import BookSection from '../components/BookSection.astro';
---

<Layout title="Art District Inc. | Custom Tattoo Studio">
  <Nav currentPage="home" />
  <Hero />
  <section class="content-section">
    <SectionTitle label="ARTIST" />
    <div class="two-col">
      <div class="artist-photo-col">
        <img src="/ADI4.jpg" alt="Artist portrait" class="artist-photo" />
      </div>
      <div class="artist-info">
        <div class="meta-label">OWNER & ARTIST</div>
        <div class="title-xl">Mike Traina</div>
        <div class="tags">
          <span class="tag tag-lg">BLACK & GREY</span>
          <span class="tag tag-lg">REALISM</span>
          <span class="tag tag-lg">FINE LINE</span>
          <span class="tag tag-lg">MURALS</span>
        </div>
        <div class="bio-text">
          [ DUMMY BIO TEXT — LOREM IPSUM DOLOR SIT AMET, CONSECTETUR ADIPISCING ELIT. SED DO EIUSMOD TEMPOR INCIDIDUNT UT LABORE ET DOLORE MAGNA ALIQUA. UT ENIM AD MINIM VENIAM, QUIS NOSTRUD EXERCITATION ULLAMCO LABORIS NISI UT ALIQUIP EX EA COMMODO CONSEQUAT. ]
        </div>
        <div class="contact-info">
          <div class="contact-row">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <span>[ EMAIL ADDRESS ]</span>
          </div>
        </div>
        <a href="/contact" class="btn">BOOK NOW</a>
      </div>
    </div>
  </section>

  <section class="content-section">
    <SectionTitle label="ARTWORK" showMore={{ url: '/artwork', label: 'VIEW FULL GALLERY' }} />
    <div class="artwork-masonry">
      <div class="artwork-main">
        <img class="mural-img" src="/ADI_artwork12.jpg" alt="Mural" />
        <img src="/ADI_artwork9.jpg" alt="Artwork 9" />
      </div>
      <div class="artwork-side">
          {[2,7,11,1].map(i => (
          <img src={"/ADI_tattoos" + i + ".jpg"} alt={"Tattoo " + i} />
        ))}
      </div>
    </div>
  </section>

  <section class="content-section">
    <SectionTitle label="LOCATION" />
    <div class="loc-two-col">
      <img src="/ADI5.jpg" alt="Storefront photo" class="loc-photo" />
      <div class="loc-map">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d14089.706344963144!2d-82.73529350080263!3d28.01143481491903!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x88c2c3c689fd0123%3A0x53c502efb6cba45d!2sMike+Traina%27s+Art+District!5e0!3m2!1sen!2sus!4v1781106186420!5m2!1sen!2sus" width="100%" height="100%" style="border:0;display:block" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
    <div class="contact-row address-row">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      <span>26489 US Hwy 19 N Suite 3, Clearwater, FL 33761</span>
      <span class="route-btn">ROUTE ›</span>
    </div>
  </section>

  <section class="content-section">
    <SectionTitle label="INSTAGRAM" showMore={{ url: 'https://www.instagram.com/artdistrictinc', label: '@artdistrictinc' }} />
    <div class="insta-section-label">LIVE INSTAGRAM FEED</div>
    <div class="elfsight-app-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" style="min-height:300px"></div>
    <div style="text-align:center;margin-top:20px">
      <a href="https://www.instagram.com/artdistrictinc" class="btn-sm" target="_blank" rel="noopener">FOLLOW ON INSTAGRAM ›</a>
    </div>
  </section>

  <section class="content-section">
    <SectionTitle label="GOOGLE REVIEWS" />
    <div class="reviews-grid">
      {[1,2,3].map(i => (
        <div class="review-card">
          <div class="stars">★★★★★</div>
          <div class="review-text">[ REVIEW TEXT PULLED FROM GOOGLE ]</div>
          <div class="review-author">— [ CLIENT NAME ] · Verified</div>
        </div>
      ))}
    </div>
    <div style="text-align:center">
      <a href="#" class="btn-sm">LEAVE A REVIEW → GOOGLE LINK</a>
    </div>
  </section>

  <BookSection />
  <Footer />
</Layout>

<style>
  .content-section {
    padding: 60px 40px;
    border-bottom: 1.5px solid var(--border-light);
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
  }

  .artist-photo-col {
    display: flex;
  }

  .artist-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .artist-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 8px;
  }

  .placeholder-img {
    background: var(--card-bg);
    border: 1.5px dashed rgba(212,200,184,0.5);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.5);
    font-family: var(--font-body);
    font-size: 0.75rem;
    text-transform: uppercase;
    text-align: center;
    padding: 20px;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .placeholder-img:hover {
    opacity: 0.8;
  }

  .placeholder-img small {
    font-size: 0.625rem;
    color: rgba(255,255,255,0.35);
    margin-top: 8px;
  }

  .bio-text {
    font-size: 20px;
    line-height: 1.9;
    color: rgba(255,255,255,0.85);
    margin: 16px 0 24px;
  }

  .meta-label {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.75rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--brand-orange);
    margin-bottom: 20px;
  }

  .title-xl {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.95;
    margin-bottom: 8px;
    color: var(--white);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 24px 0 32px;
  }

  .tag {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.75rem;
    padding: 6px 12px;
    border: 1.5px solid var(--border-light);
    text-transform: uppercase;
    color: var(--white);
  }

  .tag-lg {
    font-size: 1rem;
    padding: 12px 24px;
    letter-spacing: 2px;
    border-width: 2px;
  }

  .contact-info {
    margin-bottom: 32px;
  }

  .contact-row {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 20px;
    color: rgba(255,255,255,0.7);
    padding: 10px 0;
  }

  .btn {
    display: inline-block;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 18px 36px;
    border: 2px solid var(--brand-orange);
    background: var(--brand-orange);
    color: var(--white);
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn:hover {
    background: transparent;
    border-color: var(--brand-orange);
    color: var(--brand-orange);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(249, 92, 3, 0.3);
  }

  .btn-sm {
    display: inline-block;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 10px 20px;
    border: 1.5px solid var(--border-light);
    color: var(--white);
    cursor: pointer;
    transition: all 0.2s;
    background: var(--card-bg);
  }

  .btn-sm:hover {
    background: var(--border-light);
    color: var(--near-black);
  }

  .artwork-masonry {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 12px;
  }

  .artwork-main {
    display: flex;
    flex-direction: column;
    gap: 12px;
    line-height: 0;
    border-radius: 2px;
    overflow: hidden;
  }

  .artwork-main .mural-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .artwork-main img:not(.mural-img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 2px;
  }

  .artwork-side {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .artwork-side img {
    width: 90%;
    height: auto;
    display: block;
    border-radius: 2px;
    margin: 0 auto;
  }

  .artwork-grid-1 {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 12px;
    margin-bottom: 12px;
  }

  .artwork-grid-2 {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 12px;
    margin-top: 12px;
  }

  .grid-stack {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: 12px;
  }

  .loc-two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 12px;
  }

  .loc-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .loc-map {
    line-height: 0;
  }

  .loc-map iframe {
    width: 100%;
    height: 100%;
    display: block;
  }

  .address-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border: 1.5px solid var(--border-light);
    background: var(--card-bg);
    color: var(--white);
  }

  .route-btn {
    margin-left: auto;
    border: 1.5px solid var(--border-light);
    padding: 6px 14px;
    font-size: 9px;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    flex-shrink: 0;
    background: var(--card-bg);
    color: var(--white);
  }

  .insta-section-label {
    font-size: 9px;
    color: rgba(255,255,255,0.35);
    letter-spacing: 1px;
    margin-bottom: 24px;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 20px;
    margin-bottom: 32px;
  }

  .review-card {
    border: 1.5px solid var(--border-light);
    padding: 24px;
    background: var(--card-bg);
  }

  .stars {
    font-size: 14px;
    margin-bottom: 10px;
    letter-spacing: 2px;
    color: var(--brand-orange);
  }

  .review-text {
    font-size: 10px;
    color: rgba(255,255,255,0.7);
    line-height: 1.9;
  }

  .review-author {
    font-size: 9px;
    color: rgba(255,255,255,0.5);
    margin-top: 12px;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 10px;
  }

  @media (max-width: 1024px) {
    .two-col { grid-template-columns: 1fr; gap: 24px; }
    .artwork-grid-1 { grid-template-columns: 1fr 1fr; }
    .artwork-masonry { grid-template-columns: 1fr 1fr; }
    .reviews-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 600px) {
    .content-section { padding: 40px 16px; }
    .artwork-grid-1, .artwork-grid-2, .reviews-grid { grid-template-columns: 1fr; }
    .artwork-masonry { grid-template-columns: 1fr; }
    .artwork-side { flex-direction: row; flex-wrap: wrap; }
    .artwork-side img { width: calc(33.33% - 8px); }
    .title-xl { font-size: 24px; }
    .two-col { gap: 16px; }
    .placeholder-img[style*="height:420px"] { height: 280px !important; }
    .placeholder-img[style*="height:300px"] { height: 200px !important; }
  }
</style>
