---
export interface Props {
  title?: string;
}
const { title = 'Art District Inc. | Custom Tattoo Studio' } = Astro.props;
const bgCSS = `:root{--black:#000;--white:#fff;--gray-100:#f5f5f5;--gray-200:#e5e5e5;--gray-300:#d4d4d4;--gray-400:#a3a3a3;--gray-500:#737373;--gray-600:#525252;--gray-700:#404040;--gray-800:#262626;--gray-900:#171717;--brand-orange:#F95C03;--near-black:#050505;--card-bg:#1a1a1a;--border-light:#d4c8b8;--font-display:"Oswald",system-ui,sans-serif;--font-body:"Work Sans",system-ui,sans-serif;--fs-display:clamp(48px,9vw,88px);--fs-h1:clamp(36px,5vw,52px);--fs-h2:clamp(28px,4vw,36px);--fs-stat:clamp(34px,5vw,46px);--fs-h3:20px;--fs-body-l:18px;--fs-body:16px;--fs-label:13px;--fs-small:13px}*,*::before,*::after{box-sizing:border-box}html,body{margin:0;padding:0;width:100%;min-height:100vh}body{font-family:var(--font-body);font-size:var(--fs-body);line-height:1.65;font-weight:400;background-color:#050505;color:#fff;overflow-x:hidden;background-image:radial-gradient(ellipse 1400px 1800px at -100px 50%,rgba(249,92,3,0.8) 0%,transparent 50%),radial-gradient(ellipse 1400px 1800px at calc(100%+100px) 50%,rgba(249,92,3,0.8) 0%,transparent 50%);background-repeat:no-repeat;background-position:left center,right center;background-attachment:fixed}h1,h2,h3,h4,.display,.h1,.h2,.h3,.stat{font-family:var(--font-display);text-transform:uppercase;margin:0 0 .4em}.display{font-size:var(--fs-display);font-weight:700;line-height:0.95;letter-spacing:-0.01em}h1,.h1{font-size:var(--fs-h1);font-weight:700;line-height:1.0}h2,.h2{font-size:var(--fs-h2);font-weight:600;line-height:1.05}.stat{font-size:var(--fs-stat);font-weight:700;line-height:1.0;letter-spacing:0}h3,.h3{font-size:var(--fs-h3);font-weight:600;line-height:1.2;letter-spacing:0.02em}.body-l{font-size:var(--fs-body-l);font-weight:400;line-height:1.6}body,p{font-size:var(--fs-body);font-weight:400;line-height:1.65}.nav-link,button,.btn,.eyebrow{font-family:var(--font-body);font-weight:600;text-transform:uppercase;letter-spacing:.14em}.label{font-size:var(--fs-label);font-weight:600;line-height:1.2;letter-spacing:0.18em;text-transform:uppercase}.small{font-size:var(--fs-small);font-weight:400;line-height:1.5;letter-spacing:0.02em}.eyebrow,.tag{font-weight:500;text-transform:uppercase;letter-spacing:2px;font-size:.75rem}a{color:inherit;text-decoration:none}a:hover{color:var(--brand-orange)}.accent{color:var(--brand-orange)}img{max-width:100%;display:block}.page{display:none}.page.active{display:block}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content="Art District Inc. - Custom tattoo studio specializing in black & grey realism, portraiture, and custom murals." />
    <slot name="head" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Work+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <Fragment set:html={`<style>${bgCSS}</style>`} />
  </head>
  <body>
    <slot />
    <script>
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          document.querySelectorAll('.overlay.show, .mobile-menu.open').forEach(el => {
            el.classList.remove('show', 'open');
          });
        }
      });
    </script>
  </body>
</html>
