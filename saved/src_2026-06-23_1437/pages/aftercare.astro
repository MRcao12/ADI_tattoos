---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SectionTitle from '../components/SectionTitle.astro';
import BookSection from '../components/BookSection.astro';
---

<Layout title="Aftercare | Art District Inc.">
  <Nav currentPage="aftercare" />
  <div class="page-title">
    <div class="label">GUIDE</div>
    <div class="flex">
      <h1 class="display">Aftercare</h1>
      <div class="sub label">YOUR INK IS AN INVESTMENT. PROTECT IT.</div>
    </div>
  </div>

  <div class="timeline-section">
    <div class="meta-label label">HEALING TIMELINE</div>
    <div class="timeline-grid">
      <div class="tl-item"><div class="tl-num stat">1–3</div><div class="tl-days label">DAYS</div><div class="tl-desc body-l">RAW & TENDER<br/>MOST SENSITIVE PERIOD</div></div>
      <div class="tl-item"><div class="tl-num stat">4–7</div><div class="tl-days label">DAYS</div><div class="tl-desc body-l">PEELING & ITCHING<br/>DO NOT SCRATCH</div></div>
      <div class="tl-item"><div class="tl-num stat">2–3</div><div class="tl-days label">WEEKS</div><div class="tl-desc body-l">SURFACE HEALED<br/>DEEPER LAYERS SETTLING</div></div>
      <div class="tl-item"><div class="tl-num stat">2–3</div><div class="tl-days label">MONTHS</div><div class="tl-desc body-l">FULLY SETTLED<br/>COLOR & LINES LOCKED IN</div></div>
    </div>
  </div>

  <section class="content-section">
    <SectionTitle label="STEP BY STEP INSTRUCTIONS" />
    <div class="steps-grid">
      {[
        { num: '01', label: 'WRAP REMOVAL', desc: '[ LEAVE THE WRAP ON 2–4 HRS, OR AS YOUR ARTIST DIRECTS. WASH YOUR HANDS FIRST, THEN REMOVE GENTLY. SECOND-SKIN / SANIDERM CAN STAY ON 3–5 DAYS — PEEL IT BACK SLOWLY UNDER WARM WATER. ]' },
        { num: '02', label: 'WASHING', desc: '[ WASH 2–3× DAILY WITH LUKEWARM WATER AND FRAGRANCE-FREE ANTIBACTERIAL SOAP. CLEAN HANDS ONLY, NO WASHCLOTH. PAT DRY WITH A FRESH PAPER TOWEL. NEVER RUB. ]' },
        { num: '03', label: 'MOISTURIZING', desc: '[ ONCE FULLY DRY, APPLY A THIN LAYER OF FRAGRANCE-FREE LOTION 2–3× DAILY. THIN IS THE RULE — TOO MUCH SUFFOCATES THE SKIN AND TRAPS BACTERIA. ]' },
        { num: '04', label: 'SUN PROTECTION', desc: '[ NO DIRECT SUN FOR 3–4 WEEKS WHILE HEALING. AFTER THAT, ALWAYS APPLY SPF 50+ BEFORE SUN EXPOSURE — UV FADES INK FASTER THAN ANYTHING ELSE. ]' },
      ].map(step => (
        <div class="step-card">
          <div class="step-header"><span class="step-num">{step.num}</span><span class="step-label h3">{step.label}</span></div>
          <div class="step-body">
            <div class="placeholder-img" style="margin:12px;height:160px"><span style="font-size:9px;color:var(--gray-400)">[ PHOTO ]</span></div>
            <div class="step-text"><div class="placeholder-box body-l">{step.desc}</div></div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="content-section">
    <SectionTitle label="WHAT TO AVOID" />
    <div class="avoid-grid">
      {[
        { label: 'SOAKING', desc: 'NO POOLS, OCEAN OR BATHS DURING HEALING' },
        { label: 'PICKING', desc: 'DO NOT PICK, SCRATCH OR PEEL' },
        { label: 'DIRECT SUN', desc: 'NO DIRECT SUNLIGHT FOR MINIMUM 3 WEEKS' },
        { label: 'TIGHT CLOTHING', desc: 'KEEP FABRIC AWAY FROM FRESH INK' },
      ].map(item => (
        <div class="avoid-item">
          <div class="avoid-icon">✕</div>
          <div class="avoid-label h3">{item.label}</div>
          <div class="avoid-desc body-l">{item.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <section class="content-section">
    <SectionTitle label="LONG TERM CARE" />
    <div class="longterm-grid">
      <div class="lt-card"><div class="lt-title h3">KEEP IT MOISTURIZED</div><div class="placeholder-box body-l">[ HYDRATED SKIN KEEPS INK CRISP FOR LIFE. MOISTURIZE DAILY WITH A FRAGRANCE-FREE LOTION, ESPECIALLY AFTER SHOWERING. WELL-KEPT SKIN MEANS SHARPER LINES AND RICHER COLOR FOR YEARS. ]</div></div>
      <div class="lt-card"><div class="lt-title h3">SUN EXPOSURE</div><div class="placeholder-box body-l">[ THE SUN IS YOUR TATTOO'S #1 ENEMY — UV BREAKS PIGMENT DOWN AND BLURS YOUR WORK OVER TIME. APPLY SPF 50+ EVERY TIME THE PIECE WILL SEE SUN, FOR THE LIFE OF THE TATTOO. ]</div></div>
      <div class="lt-card"><div class="lt-title h3">TOUCH UPS</div><div class="placeholder-box body-l">[ MINOR FADING OR PATCHY SPOTS AFTER THE FIRST HEAL ARE NORMAL. WE OFFER ONE COMPLIMENTARY TOUCH-UP WITHIN 3 MONTHS OF YOUR SESSION. BOOK THROUGH THE SAME LINK AND BRING THE HEALED PIECE IN. ]</div></div>
    </div>
  </section>

  <div class="concern-banner">
    <div>
      <div class="meta-label label">HAVE A CONCERN?</div>
      <div class="placeholder-box body-l">[ IF YOUR TATTOO SHOWS SIGNS OF INFECTION OR UNUSUAL HEALING PLEASE REACH OUT DIRECTLY ]</div>
    </div>
    <a href="/contact" class="btn">CONTACT US ›</a>
  </div>

  <div class="disclaimer small">Some redness and swelling is normal for a few days. If you notice spreading redness, pus, or a fever, seek medical attention. Always follow your artist's specific instructions.</div>

  <BookSection />
  <Footer />
</Layout>

<style>
  .page-title {
    padding: 40px 40px 30px;
    border-bottom: 1.5px solid var(--border-light);
    background: var(--card-bg);
  }

  .page-title .label {
    font-family: var(--font-body);
    color: var(--brand-orange);
    margin-bottom: 12px;
  }

  .page-title .flex {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
  }

  .page-title h1 {
    margin: 0;
    color: var(--white);
  }

  .page-title .sub {
    font-family: var(--font-body);
    color: rgba(255,255,255,0.5);
    flex-shrink: 0;
  }

  .timeline-section {
    padding: 40px;
    border-bottom: 1.5px solid var(--border-light);
    background: var(--card-bg);
  }

  .meta-label {
    font-family: var(--font-body);
    text-transform: uppercase;
    color: var(--brand-orange);
    margin-bottom: 24px;
  }

  .timeline-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    border: 1.5px solid var(--border-light);
  }

  .tl-item {
    padding: 24px;
    border-right: 1.5px solid var(--border-light);
    text-align: center;
  }

  .tl-item:last-child { border-right: none; }

  .tl-num {
    font-family: var(--font-display);
    margin-bottom: 4px;
    color: var(--white);
  }

  .tl-days {
    font-family: var(--font-body);
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .tl-desc {
    color: rgba(255,255,255,0.7);
  }

  .content-section {
    padding: 60px 40px;
    border-bottom: 1.5px solid var(--border-light);
  }

  .steps-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .step-card {
    border: 1.5px solid var(--border-light);
    overflow: hidden;
    background: var(--card-bg);
  }

  .step-header {
    background: var(--near-black);
    color: var(--white);
    padding: 10px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .step-num {
    font-family: var(--font-display);
  }

  .step-label {
    font-family: var(--font-body);
    text-transform: uppercase;
  }

  .step-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .step-text {
    padding: 16px;
    display: flex;
    align-items: center;
  }

  .placeholder-img {
    background: var(--card-bg);
    border: 1.5px dashed rgba(212,200,184,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.5);
    font-family: var(--font-body);
    text-transform: uppercase;
    text-align: center;
  }

  .placeholder-box {
    background: var(--card-bg);
    border: 1px dashed rgba(212,200,184,0.3);
    padding: 16px;
    color: #c4c1bd;
  }

  .avoid-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 12px;
  }

  .avoid-item {
    border: 1.5px solid var(--border-light);
    padding: 24px;
    text-align: center;
    background: var(--card-bg);
  }

  .avoid-icon {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 32px;
    color: var(--brand-orange);
    margin-bottom: 12px;
    line-height: 1;
  }

  .avoid-label {
    font-family: var(--font-body);
    text-transform: uppercase;
    margin-bottom: 8px;
    color: var(--white);
  }

  .avoid-desc {
    color: #c4c1bd;
  }

  .longterm-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
  }

  .lt-card {
    border-left: 3px solid var(--brand-orange);
    padding: 20px 24px;
    background: var(--card-bg);
  }

  .lt-title {
    font-family: var(--font-body);
    text-transform: uppercase;
    margin-bottom: 12px;
    color: var(--white);
  }

  .concern-banner {
    padding: 40px;
    border-bottom: 1.5px solid var(--border-light);
    background: var(--card-bg);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  .concern-banner .placeholder-box {
    margin-top: 8px;
  }

  .disclaimer {
    font-family: var(--font-body);
    color: rgba(255,255,255,0.45);
    text-align: center;
    padding: 24px 40px;
  }

  .btn {
    display: inline-block;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 14px 28px;
    border: 2px solid var(--brand-orange);
    background: var(--brand-orange);
    color: var(--white);
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .btn:hover {
    background: transparent;
    border-color: var(--brand-orange);
    color: var(--brand-orange);
  }

  @media (max-width: 1024px) {
    .steps-grid { grid-template-columns: 1fr 1fr; }
    .avoid-grid { grid-template-columns: 1fr 1fr; }
    .longterm-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 600px) {
    .page-title { padding: 24px 16px; }
    .page-title .flex { flex-direction: column; align-items: flex-start; }
    .timeline-section { padding: 24px 16px; }
    .timeline-grid { grid-template-columns: 1fr 1fr; }
    .tl-item:nth-child(2) { border-right: none; }
    .tl-item:nth-child(1),
    .tl-item:nth-child(2) { border-bottom: 1.5px solid var(--border-light); }
    .content-section { padding: 40px 16px; }
    .steps-grid { grid-template-columns: 1fr; }
    .step-body { grid-template-columns: 1fr; }
    .avoid-grid { grid-template-columns: 1fr; }
    .longterm-grid { grid-template-columns: 1fr; }
    .concern-banner { flex-direction: column; padding: 24px 16px; text-align: center; }
  }
</style>
