---
const { currentPage = 'home' } = Astro.props;
const pages = [
  { id: 'artist', label: 'Artist' },
  { id: 'contact', label: 'Contact' },
  { id: 'artwork', label: 'Artwork' },
  { id: 'aftercare', label: 'Aftercare' },
];
const leftLinks = pages.slice(0, 2);
const rightLinks = pages.slice(2);
---

<nav class="nav-bar">
  <div class="nav-left">
    <button class="hamburger" id="hamburger" aria-label="Menu">☰</button>
    <div class="nav-links nav-links-left">
      {leftLinks.map(p => (
        <a href={"/" + p.id} class:list={{ 'active-link': currentPage === p.id }}>{p.label}</a>
      ))}
    </div>
  </div>
  <a href="/" class="rhino-logo">
    <img src="/ADI-rhino-crest-transparent.png" alt="Art District Inc." class="rhino-img" />
  </a>
  <div class="nav-right">
    <div class="nav-links nav-links-right">
      {rightLinks.map(p => (
        <a href={"/" + p.id} class:list={{ 'active-link': currentPage === p.id }}>{p.label}</a>
      ))}
    </div>
    <a href="/contact" class="cta-btn">BOOK NOW</a>
  </div>
</nav>

<aside class="menu-overlay" id="menu-overlay"></aside>
<aside class="mobile-menu" id="mobile-menu">
  <div class="mm-label">NAVIGATION</div>
  {pages.map(p => (
    <a href={"/" + p.id}>{p.label}<span>›</span></a>
  ))}
</aside>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('menu-overlay');

  function openMenu() {
    mobileMenu?.classList.add('open');
    overlay?.classList.add('open');
    hamburger?.classList.add('active');
  }

  function closeMenu() {
    mobileMenu?.classList.remove('open');
    overlay?.classList.remove('open');
    hamburger?.classList.remove('active');
  }

  hamburger?.addEventListener('click', () => {
    if (mobileMenu?.classList.contains('open')) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  overlay?.addEventListener('click', closeMenu);
</script>

<style>
  .nav-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 48px;
    height: 96px;
    border-bottom: 2px solid var(--orange);
    background: var(--near-black);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-left, .nav-right {
    display: flex;
    align-items: center;
    gap: 32px;
    flex: 1;
  }

  .nav-right {
    justify-content: flex-end;
  }

  .nav-right {
    justify-content: flex-end;
  }

  .nav-links {
    display: flex;
    gap: 32px;
  }

  .nav-links a {
    font-family: var(--font-heading);
    font-size: 13px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--white);
    transition: color 0.2s;
  }

  .nav-links a:hover,
  .nav-links a.active-link {
    color: var(--orange);
  }

  .rhino-logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 160px;
    height: 96px;
  }

  .rhino-img {
    max-width: 100%;
    max-height: 80px;
    width: auto;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .cta-btn {
    font-family: var(--font-heading);
    font-size: 12px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    padding: 14px 28px;
    border: 2px solid var(--orange);
    background: var(--orange);
    color: var(--white);
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .cta-btn:hover {
    background: transparent;
    border-color: var(--orange);
    color: var(--orange);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(230, 106, 37, 0.3);
  }

  .hamburger {
    display: none;
    width: 44px;
    height: 44px;
    border: 2px solid var(--orange);
    align-items: center;
    justify-content: center;
    font-size: 22px;
    cursor: pointer;
    background: var(--near-black);
    color: var(--white);
    padding: 0;
  }

  .hamburger.active {
    background: var(--near-black);
    color: var(--white);
  }

  .menu-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    z-index: 200;
  }

  .menu-overlay.open {
    display: block;
  }

  .mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    left: -280px;
    width: 280px;
    height: 100vh;
    background: var(--near-black);
    z-index: 300;
    padding: 80px 32px 32px;
    border-right: 1.5px solid var(--border-light);
    transition: left 0.3s ease;
    flex-direction: column;
    gap: 4px;
  }

  .mobile-menu.open {
    left: 0;
  }

  .mm-label {
    font-family: var(--font-heading);
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--white);
    margin-bottom: 16px;
    text-transform: uppercase;
  }

  .mobile-menu a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 0;
    font-family: var(--font-heading);
    font-size: 14px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--white);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .mobile-menu a:hover {
    color: var(--orange);
  }

  .mobile-menu a span {
    font-size: 18px;
    color: rgba(255,255,255,0.4);
  }

  @media (max-width: 768px) {
    .nav-bar {
      padding: 0 16px;
      height: 64px;
    }

    .nav-links {
      display: none;
    }

    .hamburger {
      display: flex;
      width: 36px;
      height: 36px;
      font-size: 18px;
    }

    .mobile-menu {
      display: flex;
    }

    .rhino-logo {
      width: 80px;
      height: 64px;
    }

    .rhino-img {
      max-height: 48px;
    }

    .cta-btn {
      font-size: 10px;
      padding: 10px 16px;
    }
  }

  @media (min-width: 769px) {
    .mobile-menu, .menu-overlay {
      display: none !important;
    }
  }
</style>
