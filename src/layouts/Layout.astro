---
export interface Props {
  title?: string;
}
const { title = 'Art District Inc. | Custom Tattoo Studio' } = Astro.props;
const bgCSS = `:root{--black:#000;--white:#fff;--gray-100:#f5f5f5;--gray-200:#e5e5e5;--gray-300:#d4d4d4;--gray-400:#a3a3a3;--gray-500:#737373;--gray-600:#525252;--gray-700:#404040;--gray-800:#262626;--gray-900:#171717;--brand-orange:#F95C03;--near-black:#050505;--card-bg:#1a1a1a;--border-light:#d4c8b8;--font-display:'Big Shoulders Display','Arial Narrow',sans-serif;--font-body:'Hanken Grotesk',system-ui,-apple-system,sans-serif;--font-mono:'Martian Mono',ui-monospace,'Courier New',monospace}*,*::before,*::after{box-sizing:border-box}html,body{margin:0;padding:0;width:100%;min-height:100vh}body{font-family:var(--font-body);font-weight:400;line-height:1.7;background-color:#050505;color:#fff;overflow-x:hidden;background-image:radial-gradient(ellipse 1400px 1800px at -100px 50%,rgba(249,92,3,0.8) 0%,transparent 50%),radial-gradient(ellipse 1400px 1800px at calc(100% + 100px) 50%,rgba(249,92,3,0.8) 0%,transparent 50%);background-repeat:no-repeat;background-position:left center,right center;background-attachment:fixed}h1,h2,h3,.display{font-family:var(--font-display);text-transform:uppercase;letter-spacing:.5px;line-height:.95;margin:0 0 .4em}h1,.hero-title{font-weight:800;font-size:clamp(2.5rem,6vw,5rem)}h2,.section-title{font-weight:700;font-size:clamp(1.75rem,3.5vw,2.75rem)}h3,.subhead{font-weight:700;font-size:clamp(1.25rem,2vw,1.5rem);letter-spacing:.25px}p{font-size:1rem}.lead{font-size:1.125rem}.small{font-size:.875rem}.eyebrow,.label,.tag{font-family:var(--font-mono);font-weight:500;text-transform:uppercase;letter-spacing:2px;font-size:.75rem}a{color:inherit;text-decoration:none}a:hover{color:var(--brand-orange)}img{max-width:100%;display:block}.page{display:none}.page.active{display:block}@media(max-width:600px){html{font-size:15px}}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content="Art District Inc. - Custom tattoo studio specializing in black & grey realism, portraiture, and custom murals." />
    <slot name="head" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@600;700;800&family=Hanken+Grotesk:wght@400;500;600&family=Martian+Mono:wght@400;500&display=swap" rel="stylesheet">
    <Fragment set:html={`<style>${bgCSS}</style>`} />
  </head>
  <body>
    <slot />
    <script>
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          document.querySelectorAll('.overlay.show, .mobile-menu.open').forEach(el => {
            el.classList.remove('show', 'open');
          });
        }
      });
    </script>
  </body>
</html>
