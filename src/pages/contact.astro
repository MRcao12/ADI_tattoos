---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BookSection from '../components/BookSection.astro';
---

<Layout title="Contact | Art District Inc.">
  <Nav currentPage="contact" />
  <div class="page-title">
    <div class="label">GET IN TOUCH</div>
    <div class="flex">
      <h1>Contact</h1>
      <div class="sub">APPOINTMENTS BY REQUEST ONLY</div>
    </div>
  </div>

  <div class="contact-layout">
    <div class="contact-info-col">
      <div class="meta-label">REACH US DIRECTLY</div>
      <div class="contact-methods">
        <div class="contact-row-large">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <div>
            <div class="contact-method-label">EMAIL US</div>
            <div class="contact-method-value">[ EMAIL ADDRESS ]</div>
          </div>
          <span class="contact-arrow">›</span>
        </div>
        <div class="contact-row-large">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          <div>
            <div class="contact-method-label">DM ON INSTAGRAM</div>
            <div class="contact-method-value">[ @INSTAGRAM HANDLE ]</div>
          </div>
          <span class="contact-arrow">›</span>
        </div>
      </div>

      <div class="meta-label" style="margin-top:48px">HOURS</div>
      <div class="hours-table">
        <div class="hours-row"><span>MON — FRI</span><span>[ HOURS ]</span></div>
        <div class="hours-row"><span>SATURDAY</span><span>[ HOURS ]</span></div>
        <div class="hours-row"><span>SUNDAY</span><span>BY APPT ONLY</span></div>
      </div>
      <div class="appt-note">ALL SESSIONS BY APPOINTMENT ONLY</div>
    </div>

    <div class="contact-map-col">
      <div class="meta-label">FIND US</div>
      <div class="loc-grid">
        <div class="placeholder-img" style="height:160px"><span>[ STOREFRONT PHOTO 1 ]</span></div>
        <div class="placeholder-img" style="height:160px"><span>[ STOREFRONT PHOTO 2 ]</span></div>
      </div>
      <div class="placeholder-img" style="height:260px;margin-bottom:12px">
        <span>[ GOOGLE MAPS EMBED ]</span>
        <small>LIVE INTERACTIVE MAP</small>
      </div>
      <div class="address-block">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <div>
          <div>[ 26489 FULL STREET ADDRESS ]</div>
          <div class="addr-sub">[ CITY, STATE, ZIP ]</div>
        </div>
        <span class="dir-btn">GET DIRECTIONS ›</span>
      </div>
    </div>
  </div>

  <div class="social-section">
    <div class="meta-label" style="text-align:center;margin-bottom:32px">FOLLOW THE WORK</div>
    <div class="social-grid">
      <a href="#" class="social-card">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        <div>INSTAGRAM</div>
        <div class="social-handle">[ @HANDLE ]</div>
      </a>
      <a href="#" class="social-card">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        <div>FACEBOOK</div>
        <div class="social-handle">[ PAGE LINK ]</div>
      </a>
      <a href="#" class="social-card">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <div>YELP</div>
        <div class="social-handle">[ PROFILE ]</div>
      </a>
    </div>
  </div>

  <BookSection />
  <Footer />
</Layout>

<style>
  .page-title {
    padding: 40px 40px 30px;
    border-bottom: 1.5px solid var(--black);
  }

  .page-title .label {
    font-family: var(--font-heading);
    font-size: 9px;
    letter-spacing: 3px;
    color: var(--gray-400);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .page-title .flex {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
  }

  .page-title h1 {
    font-family: var(--font-heading);
    font-size: 36px;
    letter-spacing: 2px;
    margin: 0;
  }

  .page-title .sub {
    font-size: 9px;
    color: var(--gray-500);
    letter-spacing: 2px;
    text-transform: uppercase;
    flex-shrink: 0;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1.5px solid var(--black);
  }

  .contact-info-col {
    padding: 50px 40px;
    border-right: 1.5px solid var(--black);
  }

  .contact-map-col {
    padding: 50px 40px;
  }

  .meta-label {
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-bottom: 24px;
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 48px;
  }

  .contact-row-large {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    border: 1.5px solid var(--black);
    cursor: pointer;
    transition: all 0.2s;
  }

  .contact-row-large:hover {
    background: var(--gray-100);
  }

  .contact-method-label {
    font-size: 9px;
    color: var(--gray-500);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 3px;
  }

  .contact-method-value {
    font-size: 15px;
    letter-spacing: 1px;
  }

  .contact-arrow {
    margin-left: auto;
    font-size: 16px;
    color: var(--gray-400);
  }

  .hours-table {
    border: 1.5px solid var(--black);
    overflow: hidden;
    margin-bottom: 48px;
  }

  .hours-row {
    display: flex;
    border-bottom: 1px solid var(--gray-300);
  }

  .hours-row:last-child { border-bottom: none; }

  .hours-row span:first-child {
    flex: 1;
    padding: 14px 16px;
    font-size: 9px;
    letter-spacing: 1px;
    border-right: 1px solid var(--gray-300);
    color: var(--gray-600);
    text-transform: uppercase;
  }

  .hours-row span:last-child {
    flex: 1;
    padding: 14px 16px;
    font-size: 12px;
    text-align: right;
  }

  .appt-note {
    border: 1px dashed var(--gray-400);
    padding: 12px;
    text-align: center;
    font-size: 9px;
    color: var(--gray-500);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .loc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 12px;
  }

  .placeholder-img {
    background: var(--gray-200);
    border: 1.5px dashed var(--gray-400);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--gray-500);
    font-family: var(--font-heading);
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-align: center;
    padding: 20px;
  }

  .placeholder-img small {
    font-size: 8px;
    color: var(--gray-400);
    margin-top: 8px;
    letter-spacing: 1px;
  }

  .address-block {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border: 1.5px solid var(--black);
    font-size: 12px;
  }

  .addr-sub {
    font-size: 9px;
    color: var(--gray-500);
    margin-top: 2px;
  }

  .dir-btn {
    margin-left: auto;
    border: 1.5px solid var(--black);
    padding: 8px 16px;
    font-size: 9px;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    flex-shrink: 0;
  }

  .social-section {
    padding: 60px 40px;
    border-bottom: 1.5px solid var(--black);
    background: var(--gray-100);
  }

  .social-grid {
    display: flex;
    gap: 16px;
    justify-content: center;
  }

  .social-card {
    border: 1.5px solid var(--black);
    padding: 24px 40px;
    text-align: center;
    background: var(--white);
    min-width: 160px;
    transition: all 0.2s;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .social-card:hover {
    border-color: var(--orange);
  }

  .social-card div {
    font-family: var(--font-heading);
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .social-handle {
    font-size: 9px !important;
    color: var(--gray-500);
    font-family: var(--font-body) !important;
  }

  @media (max-width: 1024px) {
    .contact-layout { grid-template-columns: 1fr; }
    .contact-info-col { border-right: none; }
    .social-grid { flex-wrap: wrap; }
  }

  @media (max-width: 600px) {
    .page-title { padding: 24px 16px; }
    .page-title .flex { flex-direction: column; align-items: flex-start; }
    .page-title h1 { font-size: 24px; }
    .contact-info-col { padding: 32px 16px; }
    .contact-map-col { padding: 32px 16px; }
    .social-section { padding: 40px 16px; }
    .social-card { min-width: 120px; padding: 20px 24px; }
    .hours-row span:first-child,
    .hours-row span:last-child { padding: 10px 12px; font-size: 10px; }
  }
</style>
